JAVA_VERSION=17
NODE_VERSION=24

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

MODPACK_DIR=Modpack-Modern
MODPACK_REPO=https://github.com/TerraFirmaGreg-Team/Modpack-Modern.git
MODPACK_TAG=

FQE_REPO=jmecn/ftb-quest-export
FQE_VERSION=

SITE_VIEWER_REPO=jmecn/QuestBook-React
SITE_VIEWER_VERSION=

HMC_REPO=3arthqu4ke/headlessmc
HMC_VERSION=2.9.0

EXPORT_WARMUP_TICKS=100
EXPORT_WORLD_DELAY_TICKS=600
EXPORT_TIMEOUT_SECONDS=7200

EXPORT_CACHE_KEY_PREFIX=quest-export

EXPORT_ARTIFACT_NAME=quest-book
EXPORT_WORKFLOW_NAME="Build quest book"

EXPORT_ROOT_DIR=export
QUEST_SUBDIR=quest-export
SITE_OUTPUT_DIR=site

SITE_RELEASE_ASSET_NAME=quest-book-site.tar.gz
SITE_RELEASE_HASH_LENGTH=7

# Empty = https://<owner>.github.io/<repo>/build.json from GITHUB_REPOSITORY.
BUILD_JSON_URL=

RECIPE_BOOK_BASE_URL=https://wiki.terrafirmagreg.team/modern/recipe-book/
FIELD_GUIDE_BASE_URL=https://wiki.terrafirmagreg.team/modern/field-guide/
SITE_BASE_URL=https://wiki.terrafirmagreg.team/modern/quest-book/

OG_IMAGE_URL=https://wiki.terrafirmagreg.team/logo.png

# Gitalk comments (optional). When GITALK_ENABLED=true, write_site_config embeds gitalk in site-config.json.
# Create a GitHub OAuth App; use a CORS proxy for token exchange in production (avoid exposing clientSecret).
# GITALK_ENABLED=true
# GITALK_CLIENT_ID=
# GITALK_CLIENT_SECRET=
# GITALK_REPO=
# GITALK_OWNER=
# GITALK_ADMIN=user1,user2
# GITALK_PROXY=https://your-proxy.example/login/oauth/access_token
# GITALK_DISTRACTION_FREE=false

RUNNER_HOME=/home/runner
